# ── Telegram ──────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated chat IDs (run get_chat_id.py to find yours)
TELEGRAM_CHAT_IDS=111111111,222222222

# ── LLM Provider ─────────────────────────────────
# Options: groq (free), anthropic, gemini
LLM_PROVIDER=groq

# API key for your chosen provider
# Groq: https://console.groq.com/keys (free)
# Anthropic: https://console.anthropic.com/
# Gemini: https://aistudio.google.com/apikey
LLM_API_KEY=gsk_your_groq_api_key_here

# Model (optional — defaults per provider):
# groq: llama-3.3-70b-versatile
# anthropic: claude-haiku-4-5-20251001
# gemini: gemini-2.0-flash-lite
LLM_MODEL=

# ── Tuning ────────────────────────────────────────
# Max articles in final digest (default: 15)
MAX_ARTICLES=15

# Minimum LLM relevance score 0-10 (default: 5)
MIN_RELEVANCE=5

# State file path (default: data/seen_articles.json)
STATE_FILE=data/seen_articles.json
